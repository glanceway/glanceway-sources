---
import Layout from "../../layouts/Layout.astro";
import SourceDetailPage from "../../components/SourceDetailPage.astro";
import { getSources, getSourceDetail } from "../../lib/sources";

export function getStaticPaths() {
  const sources = getSources();
  return sources.map((s) => ({
    params: { slug: s.id },
    props: { id: s.id },
  }));
}

const { id } = Astro.props as { id: string };
const source = getSourceDetail(id)!;
---

<Layout
  title={`${source.name} menu bar source for Mac — Glanceway`}
  description={`${source.description.replace(/\.?\s*$/, '.')} Install ${source.name} in Glanceway and get ${source.category.toLowerCase()} updates in your macOS menu bar, one click away.`}
>
  <SourceDetailPage id={id} locale="en" />
</Layout>
