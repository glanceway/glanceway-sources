---
import Layout from "../layouts/Layout.astro";
import LandingPage from "../components/LandingPage.astro";
import { getLandingPage } from "../content/landingPages";

const slug = "menu-bar-news-reader-mac";
const page = getLandingPage(slug, "en")!;
---

<Layout title={page.title} description={page.description} singleLocale>
  <LandingPage slug={slug} locale="en" />
</Layout>
