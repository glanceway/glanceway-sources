---
import "../styles/global.css";
import { Sun, Moon, Monitor } from "@lucide/astro";
import LanguageSwitcher from "../components/LanguageSwitcher.astro";
import {
  useTranslations,
  getLocalePath,
  defaultLocale,
  locales,
  localeKeys,
  nonDefaultLocales,
} from "../i18n/index";

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  locale?: string;
  hideLanguageSwitcher?: boolean;
  ogImage?: string;
}

const { title, locale = defaultLocale, hideLanguageSwitcher = false, ogImage, keywords: keywordsProp } = Astro.props;
const t = useTranslations(locale);
const dir = locales[locale]?.dir ?? "ltr";
const currentPath = Astro.url.pathname;

const siteUrl = "https://sources.glanceway.app";
const description = Astro.props.description || t("hero.description");
const keywords = keywordsProp || t("seo.keywords");

// Build base path for hreflang (strip locale prefix)
function getBasePath(path: string, loc: string): string {
  if (loc === defaultLocale) return path;
  const prefix = `/${loc}`;
  if (path === prefix || path === `${prefix}/`) return "/";
  if (path.startsWith(`${prefix}/`)) return path.slice(prefix.length);
  return path;
}
const basePath = getBasePath(currentPath, locale);

// Canonical URL: always point to the current locale's page
const canonicalUrl = new URL(currentPath, siteUrl).href;

// OG image
const ogImageUrl = ogImage ? new URL(ogImage, siteUrl).href : new URL("/app-screenshot.png", siteUrl).href;

// JSON-LD structured data for the homepage
const isHomePage = basePath === "/" || basePath === "";
const jsonLd = isHomePage ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Glanceway",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "macOS",
  "description": t("hero.description"),
  "url": siteUrl,
  "image": ogImageUrl,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
  },
  "installUrl": "https://apps.apple.com/app/6758926117",
}) : null;
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Glanceway" />
    <meta property="og:locale" content={locale.replace("-", "_")} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:site" content="@glancewayapp" />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Glanceway" />
    <link rel="manifest" href="/site.webmanifest" />
    {
      localeKeys.map((loc) => (
        <link
          rel="alternate"
          hreflang={loc === defaultLocale ? "x-default" : loc}
          href={new URL(getLocalePath(loc, basePath), siteUrl).href}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="en"
      href={new URL(getLocalePath(defaultLocale, basePath), siteUrl).href}
    />
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    {locale === defaultLocale && (
      <script is:inline define:vars={{ nonDefaultLocales, basePath, defaultLocale }}>
        (function () {
          var pref = localStorage.getItem("locale-preference");
          var match;
          if (pref && pref !== defaultLocale) {
            match = pref;
          } else if (!pref) {
            var lang = (navigator.language || "").toLowerCase();
            var supported = nonDefaultLocales;
            match =
              supported.find(function (l) { return lang === l; }) ||
              supported.find(function (l) { return lang.startsWith(l + "-"); }) ||
              supported.find(function (l) { return l === lang.split("-")[0]; });
          }
          if (match) {
            var path = basePath === "/" || basePath === "" ? "/" : basePath;
            window.location.replace("/" + match + path);
          }
        })();
      </script>
    )}
    <script is:inline>
      (function () {
        var theme = localStorage.getItem("theme") || "system";
        var isDark =
          theme === "dark" ||
          (theme === "system" &&
            window.matchMedia("(prefers-color-scheme: dark)").matches);
        if (isDark) document.documentElement.classList.add("dark");

        var modes = ["light", "dark", "system"];

        function getTheme() {
          return localStorage.getItem("theme") || "system";
        }

        function applyTheme(t) {
          var d =
            t === "dark" ||
            (t === "system" &&
              window.matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.classList.toggle("dark", d);
          var icons = document.querySelectorAll(".theme-icon");
          icons.forEach(function (icon) {
            icon.style.display = icon.dataset.theme === t ? "" : "none";
          });
        }

        function init() {
          var btn = document.getElementById("theme-toggle");
          if (!btn || btn.dataset.themeInit) return;
          btn.dataset.themeInit = "1";
          btn.addEventListener("click", function () {
            var cur = getTheme();
            var next = modes[(modes.indexOf(cur) + 1) % modes.length];
            localStorage.setItem("theme", next);
            applyTheme(next);
          });
          applyTheme(getTheme());
          window
            .matchMedia("(prefers-color-scheme: dark)")
            .addEventListener("change", function () {
              if (getTheme() === "system") applyTheme("system");
            });
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init);
        } else {
          init();
        }
      })();
    </script>
  </head>
  <body
    class="min-h-screen text-gray-900 dark:text-gray-100"
  >
    <header class="sticky top-0 z-50 header-blend">
      <div
        class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4"
      >
        <a
          href={getLocalePath(locale, "/")}
          class="flex items-center gap-2.5 text-lg font-bold tracking-tight text-gray-900 no-underline dark:text-white"
        >
          <img src="/logo.svg" alt="Glanceway" class="h-8 w-8 dark:invert" />
          Glanceway
        </a>
        <nav class="flex items-center gap-4 text-sm">
          <a
            href={getLocalePath(locale, "/sources")}
            class="font-medium text-gray-600 no-underline hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
          >{t("nav.sources")}</a>
          {!hideLanguageSwitcher && <LanguageSwitcher locale={locale} currentPath={currentPath} />}
          <button
            id="theme-toggle"
            class="flex h-8 w-8 items-center justify-center rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-white transition-colors"
            aria-label="Toggle theme"
          >
            <Sun class="theme-icon h-4 w-4" data-theme="light" />
            <Moon class="theme-icon h-4 w-4" data-theme="dark" />
            <Monitor class="theme-icon h-4 w-4" data-theme="system" />
          </button>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="mx-auto max-w-6xl px-6 py-10">
        <div class="flex flex-col gap-8 sm:flex-row sm:justify-between">
          <!-- Left: brand + copyright -->
          <div>
            <div class="flex items-center gap-2 text-sm font-semibold text-gray-900 dark:text-white">
              <img src="/logo.svg" alt="Glanceway" class="h-5 w-5 dark:invert" />
              Glanceway
            </div>
            <p class="mt-3 text-xs text-gray-400 dark:text-gray-500">
              {t("footer.copyright", { year: new Date().getFullYear().toString() })}
            </p>
          </div>
          <!-- Right: links -->
          <div class="flex gap-12 text-sm">
            <div class="flex flex-col gap-2">
              <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Social</span>
              <a href="https://x.com/glancewayapp" target="_blank" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">X (Twitter)</a>
              <a href="https://github.com/glanceway/glanceway-sources" target="_blank" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">GitHub</a>
            </div>
            <div class="flex flex-col gap-2">
              <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Support</span>
              <a href="mailto:support@glanceway.app" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">support@glanceway.app</a>
              <a href="/privacy" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">Privacy Policy</a>
            </div>
          </div>
        </div>
      </div>
    </footer>
    <script is:inline>
      (function () {
        var h = document.querySelector(".header-blend");
        if (!h) return;
        function u() { h.classList.toggle("scrolled", window.scrollY > 10); }
        u();
        window.addEventListener("scroll", u, { passive: true });
      })();
    </script>
  </body>
</html>
