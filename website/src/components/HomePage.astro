---
import { Download, ArrowRight } from "@lucide/astro";
import { useTranslations, getLocalePath } from "../i18n/index";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const sourcesPath = getLocalePath(locale, "/sources/");

const sourceBadges = [
  "Hacker News",
  "Reddit",
  "GitHub",
  "Product Hunt",
  "Stock Quotes",
  "Crypto",
  "StackOverflow",
  "RSS Feeds",
  "Earthquake Alerts",
  "Spaceflight",
  "npm Packages",
  "TV Schedules",
];
---

<!-- Hero -->
<div class="mx-auto max-w-6xl px-6 pt-24 pb-12 sm:pt-32 sm:pb-16 text-center">
  <!-- Tagline pill -->
  <div
    class="mb-8 inline-flex items-center rounded-full border border-gray-200/60 dark:border-gray-700/60 bg-white/60 dark:bg-white/5 px-4 py-1.5 text-xs font-medium text-gray-500 dark:text-gray-400"
    style="backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);"
  >
    {t("hero.tagline")}
  </div>

  <!-- Title -->
  <h1
    class="mx-auto max-w-3xl text-5xl font-extrabold tracking-tight leading-[1.1] sm:text-7xl gradient-text"
  >
    {t("hero.title")}
  </h1>

  <!-- Description -->
  <p
    class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-gray-500 dark:text-gray-400"
  >
    {t("hero.description")}
  </p>

  <!-- CTA buttons -->
  <div
    class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4"
  >
    <a
      href="https://apps.apple.com/app/6758926117"
      target="_blank"
      class="btn-primary w-full sm:w-auto"
    >
      <Download class="h-4 w-4" />
      {t("hero.download")}
    </a>
    <a
      href={sourcesPath}
      class="inline-flex w-full sm:w-auto items-center justify-center rounded-xl border border-gray-200 dark:border-gray-700 px-6 py-3 text-sm font-semibold text-gray-700 dark:text-gray-300 no-underline hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
    >
      {t("hero.browseSources")}
    </a>
  </div>
</div>

<!-- App screenshot with glow -->
<div class="mx-auto max-w-6xl px-6 pb-24 sm:pb-32">
  <div class="relative mx-auto max-w-md">
    <div
      class="absolute -inset-2 rounded-3xl bg-gradient-to-br from-sky-400/15 via-blue-500/8 to-cyan-400/15 dark:from-sky-400/20 dark:via-blue-500/10 dark:to-cyan-400/20 blur-xl"
      aria-hidden="true"
    >
    </div>
    <img
      src="/app-screenshot.webp"
      alt="Glanceway app screenshot"
      class="relative w-full rounded-2xl shadow-2xl ring-1 ring-gray-900/5 dark:ring-white/10 aspect-square object-cover"
    />
  </div>
</div>

<!-- Features -->
<div class="mx-auto max-w-5xl px-6 pb-28">
  <div class="text-center animate-on-scroll">
    <h2
      class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl"
    >
      {t("features.title")}
    </h2>
    <p
      class="mx-auto mt-4 mb-0 max-w-xl text-base text-gray-500 dark:text-gray-400"
    >
      {t("features.subtitle")}
    </p>
  </div>

  <!-- Feature 1: Community Sources (text left, visual right) -->
  <div
    class="mt-24 flex flex-col sm:flex-row gap-8 sm:gap-14 items-center animate-on-scroll"
  >
    <div class="flex-1 min-w-0">
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white">
        {t("features.communitySources.title")}
      </h3>
      <p
        class="mt-3 text-base leading-relaxed text-gray-500 dark:text-gray-400"
      >
        {t("features.communitySources.description")}
      </p>
      <a
        href={sourcesPath}
        class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-gray-600 no-underline hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
      >
        {t("features.browseSources")}
        <ArrowRight class="h-3.5 w-3.5" />
      </a>
    </div>
    <div class="flex-1 min-w-0 -order-1 sm:order-none">
      <div class="flex flex-wrap gap-2 justify-center sm:justify-start">
        {
          sourceBadges.map((name) => (
            <span class="inline-flex items-center rounded-full bg-white/80 dark:bg-gray-800/80 px-3.5 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 ring-1 ring-gray-200/60 dark:ring-gray-700/60">
              {name}
            </span>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Feature 2: RSS Support (visual left, text right) -->
  <div
    class="flex flex-col sm:flex-row-reverse gap-8 sm:gap-14 items-start mt-28 animate-on-scroll"
  >
    <div class="flex-1 min-w-0">
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white">
        {t("features.rss.title")}
      </h3>
      <p
        class="mt-3 text-base leading-relaxed text-gray-500 dark:text-gray-400"
      >
        {t("features.rss.description")}
      </p>
      <div class="mt-4 flex items-center gap-4">
        <a
          href="https://rsshub.netlify.app/routes"
          target="_blank"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-600 no-underline hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
        >
          {t("features.rss.linkRsshub")}
          <ArrowRight class="h-3.5 w-3.5" />
        </a>
        <a
          href="https://rss.app"
          target="_blank"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-600 no-underline hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
        >
          {t("features.rss.linkRssApp")}
          <ArrowRight class="h-3.5 w-3.5" />
        </a>
      </div>
    </div>
    <div class="flex-1 min-w-0 w-full -order-1 sm:order-none">
      <div class="space-y-2.5">
        {
          [
            "https://hnrss.org/frontpage",
            "https://www.reddit.com/r/programming/.rss",
            "https://feeds.arstechnica.com/arstechnica/technology-lab",
          ].map((url) => (
            <div class="flex items-center gap-3 rounded-xl bg-white/80 dark:bg-gray-800/60 px-4 py-3">
              <span class="shrink-0 text-orange-500 dark:text-orange-400">
                <svg
                  class="h-4 w-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <path d="M4 11a9 9 0 0 1 9 9" />
                    <path d="M4 4a16 16 0 0 1 16 16" />
                    <circle cx="5" cy="19" r="1" />
                  </>
                </svg>
              </span>
              <span class="text-sm text-gray-600 dark:text-gray-300 truncate font-mono">
                {url}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Feature 3: Create Sources with AI (text left, visual right) -->
  <div
    class="flex flex-col sm:flex-row gap-8 sm:gap-14 items-start mt-28 animate-on-scroll"
  >
    <div class="flex-1 min-w-0">
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white">
        {t("features.aiCreate.title")}
      </h3>
      <p
        class="mt-3 text-base leading-relaxed text-gray-500 dark:text-gray-400"
      >
        {t("features.aiCreate.description")}
      </p>
      <div class="mt-4 flex flex-col gap-3">
        <div class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-gray-600 dark:text-gray-400"
            >{t("features.aiCreate.linkDocs")}</span
          >
          <a
            href="https://github.com/glanceway/skills/blob/main/skills/glanceway-source/SKILL.md"
            target="_blank"
            class="inline-flex items-center gap-1.5 rounded-lg bg-gray-100 dark:bg-gray-800 px-3 py-2 text-xs font-medium text-gray-700 dark:text-gray-300 no-underline hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
          >
            <ArrowRight class="h-3.5 w-3.5" />
            SKILL.md
          </a>
        </div>
        <div class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-gray-600 dark:text-gray-400"
            >{t("features.aiCreate.linkCli")}</span
          >
          <div class="relative group">
            <code
              class="block rounded-lg bg-gray-100 dark:bg-gray-800 px-3 py-2 pr-9 text-xs text-gray-700 dark:text-gray-300 break-all"
              >{t("features.aiCreate.codeCommand")}</code
            >
            <button
              type="button"
              class="copy-btn absolute right-2 top-1/2 -translate-y-1/2 rounded p-1 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition-colors"
              data-copy={t("features.aiCreate.codeCommand")}
            >
              <svg
                class="h-4 w-4 copy-icon"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><rect
                  x="9"
                  y="9"
                  width="13"
                  height="13"
                  rx="2"
                  stroke-width="2"></rect><path
                  d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
                  stroke-width="2"></path></svg
              >
              <svg
                class="h-4 w-4 check-icon hidden"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path></svg
              >
            </button>
          </div>
        </div>
      </div>
    </div>
    <div class="flex-1 min-w-0 w-full -order-1 sm:order-none">
      <div class="space-y-2.5">
        {
          [
            t("features.aiCreate.prompt1"),
            t("features.aiCreate.prompt2"),
            t("features.aiCreate.prompt3"),
          ].map((prompt) => (
            <div class="rounded-xl bg-white/80 dark:bg-gray-800/60 px-4 py-3 text-sm text-gray-700 dark:text-gray-300 italic">
              &ldquo;{prompt}&rdquo;
            </div>
          ))
        }
      </div>
      <ol class="mt-5 space-y-2.5 text-sm text-gray-500 dark:text-gray-400">
        <li class="flex gap-3 items-start">
          <span
            class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-xs font-semibold text-gray-600 dark:text-gray-300"
            >1</span
          >
          <span>{t("features.aiCreate.step1")}</span>
        </li>
        <li class="flex gap-3 items-start">
          <span
            class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-xs font-semibold text-gray-600 dark:text-gray-300"
            >2</span
          >
          <span>{t("features.aiCreate.step2")}</span>
        </li>
        <li class="flex gap-3 items-start">
          <span
            class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-xs font-semibold text-gray-600 dark:text-gray-300"
            >3</span
          >
          <span>{t("features.aiCreate.step3")}</span>
        </li>
      </ol>
    </div>
  </div>

  <!-- Feature 4: AI Reading & Summarization (visual left, text right) -->
  <div
    class="flex flex-col sm:flex-row-reverse gap-8 sm:gap-14 items-start mt-28 animate-on-scroll"
  >
    <div class="flex-1 min-w-0">
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white">
        {t("features.aiReading.title")}
      </h3>
      <p
        class="mt-3 text-base leading-relaxed text-gray-500 dark:text-gray-400"
      >
        {t("features.aiReading.description")}
      </p>
      <div class="mt-4 flex flex-col gap-3">
        <div class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-gray-600 dark:text-gray-400"
            >{t("features.aiReading.linkDesktop")}</span
          >
          <a
            href="https://github.com/glanceway/glanceway-mcp/releases/latest/download/glanceway.mcpb"
            class="inline-flex items-center gap-1.5 rounded-lg bg-gray-100 dark:bg-gray-800 px-3 py-2 text-xs font-medium text-gray-700 dark:text-gray-300 no-underline hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
          >
            <Download class="h-3.5 w-3.5" />
            glanceway.mcpb
          </a>
        </div>
        <div class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-gray-600 dark:text-gray-400"
            >{t("features.aiReading.linkCode")}</span
          >
          <div class="relative group">
            <code
              class="block rounded-lg bg-gray-100 dark:bg-gray-800 px-3 py-2 pr-9 text-xs text-gray-700 dark:text-gray-300 break-all"
              >{t("features.aiReading.codeCommand")}</code
            >
            <button
              type="button"
              class="copy-btn absolute right-2 top-1/2 -translate-y-1/2 rounded p-1 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition-colors"
              data-copy={t("features.aiReading.codeCommand")}
            >
              <svg
                class="h-4 w-4 copy-icon"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><rect
                  x="9"
                  y="9"
                  width="13"
                  height="13"
                  rx="2"
                  stroke-width="2"></rect><path
                  d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
                  stroke-width="2"></path></svg
              >
              <svg
                class="h-4 w-4 check-icon hidden"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path></svg
              >
            </button>
          </div>
        </div>
      </div>
    </div>
    <div class="flex-1 min-w-0 w-full -order-1 sm:order-none">
      <div class="space-y-4 text-sm leading-relaxed">
        <!-- User message -->
        <div class="flex gap-3 justify-end">
          <div
            class="rounded-2xl rounded-tr-sm bg-sky-100 dark:bg-sky-900/50 px-4 py-2.5 text-sky-900 dark:text-sky-100 max-w-[90%]"
          >
            {t("features.aiReading.chatUser")}
          </div>
        </div>
        <!-- AI response -->
        <div class="flex gap-3">
          <div
            class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-gray-200 dark:bg-gray-700"
          >
            <span class="text-xs font-bold text-gray-500 dark:text-gray-400">AI</span>
          </div>
          <div
            class="rounded-2xl rounded-tl-sm bg-white/80 dark:bg-gray-800/60 px-4 py-2.5 text-gray-700 dark:text-gray-300 max-w-[90%] [&_b]:font-medium"
          >
            <p class="text-xs text-gray-400 dark:text-gray-500 mb-1.5">
              {t("features.aiReading.chatStatus")}
            </p>
            <p set:html={t("features.aiReading.chatResponse")} />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- CTA -->
<div class="mx-auto max-w-5xl px-6 pb-28">
  <div class="relative overflow-hidden rounded-3xl">
    <div
      class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-800 to-sky-900 dark:from-gray-800 dark:via-gray-900 dark:to-sky-950"
      aria-hidden="true"
    >
    </div>
    <div class="relative px-6 py-20 text-center sm:px-16">
      <h2
        class="text-3xl font-bold tracking-tight text-white sm:text-4xl"
      >
        {t("cta.title")}
      </h2>
      <p class="mx-auto mt-4 max-w-lg text-base text-gray-300">
        {t("cta.description")}
      </p>
      <div class="mt-10">
        <a
          href="https://apps.apple.com/app/6758926117"
          target="_blank"
          class="inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3 text-sm font-semibold text-gray-900 no-underline hover:bg-gray-100 transition-colors shadow-lg"
        >
          <Download class="h-4 w-4" />
          {t("hero.download")}
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  // Copy buttons
  document.querySelectorAll(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-copy");
      if (!text) return;
      await navigator.clipboard.writeText(text);
      const copyIcon = btn.querySelector(".copy-icon");
      const checkIcon = btn.querySelector(".check-icon");
      copyIcon?.classList.add("hidden");
      checkIcon?.classList.remove("hidden");
      setTimeout(() => {
        copyIcon?.classList.remove("hidden");
        checkIcon?.classList.add("hidden");
      }, 2000);
    });
  });

  // Scroll-triggered animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
  );

  document.querySelectorAll(".animate-on-scroll").forEach((el) => {
    observer.observe(el);
  });
</script>
