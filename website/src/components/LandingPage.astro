---
import { Download } from "@lucide/astro";
import SourceCard from "./SourceCard.astro";
import { getLandingPage } from "../content/landingPages";
import { getSources } from "../lib/sources";
import { useTranslations, getLocalePath } from "../i18n/index";

interface Props {
  slug: string;
  locale: string;
}

const { slug, locale } = Astro.props;
const page = getLandingPage(slug, locale)!;
const t = useTranslations(locale);

const allSources = getSources();
const relatedSources = page.relatedSourceIds
  .map((id) => allSources.find((s) => s.id === id))
  .filter((s): s is NonNullable<typeof s> => s !== undefined);

const siteUrl = "https://glanceway.app";
const canonical = `${siteUrl}${getLocalePath(locale, `/${slug}/`)}`;

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": page.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
});

const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": page.h1,
  "description": page.description,
  "url": canonical,
  "isPartOf": {
    "@type": "WebSite",
    "name": "Glanceway",
    "url": siteUrl,
  },
});

const categoryHref = page.categorySlug
  ? getLocalePath(locale, `/categories/${page.categorySlug}/`)
  : null;
---

<script type="application/ld+json" set:html={faqJsonLd} />
<script type="application/ld+json" set:html={articleJsonLd} />

<article class="mx-auto max-w-3xl px-6 py-14">
  <header class="mb-10">
    <h1 class="mb-4 text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl dark:text-white">
      {page.h1}
    </h1>
    <p class="text-lg leading-relaxed text-gray-500 dark:text-gray-400">
      {page.hero}
    </p>
  </header>

  <div class="mb-10 flex flex-wrap items-center gap-3">
    <a
      href="https://apps.apple.com/app/6758926117"
      target="_blank"
      class="btn-primary"
    >
      <Download class="h-4 w-4" />
      {t("hero.download")}
    </a>
    <a
      href={getLocalePath(locale, "/sources/")}
      class="inline-flex items-center justify-center rounded-xl border border-gray-200 dark:border-gray-700 px-5 py-2.5 text-sm font-semibold text-gray-700 dark:text-gray-300 no-underline hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
    >
      {t("hero.browseSources")}
    </a>
  </div>

  <div class="prose prose-gray dark:prose-invert max-w-none">
    {
      page.sections.map((section) => (
        <section class="mt-10">
          <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
            {section.heading}
          </h2>
          {section.body.map((para) => (
            <p class="mt-4 leading-relaxed text-gray-600 dark:text-gray-300">{para}</p>
          ))}
        </section>
      ))
    }
  </div>

  {relatedSources.length > 0 && (
    <section class="mt-16">
      <h2 class="mb-5 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
        {t("related.title")}
      </h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {relatedSources.map((s) => (
          <SourceCard
            id={s.id}
            name={s.name}
            description={s.description}
            category={s.category}
            tags={s.tags}
            author={s.author}
            type={s.type}
            locale={locale}
          />
        ))}
      </div>
      {categoryHref && (
        <div class="mt-5">
          <a
            href={categoryHref}
            class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-600 no-underline hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
          >
            {t("landing.browseCategory")} →
          </a>
        </div>
      )}
    </section>
  )}

  <section class="mt-16">
    <h2 class="mb-5 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
      {t("landing.faqTitle")}
    </h2>
    <div class="space-y-5">
      {
        page.faqs.map((faq) => (
          <details class="group rounded-2xl border border-gray-200 dark:border-gray-800 bg-white/60 dark:bg-gray-900/60 px-5 py-4 open:shadow-sm">
            <summary class="cursor-pointer list-none font-semibold text-gray-900 dark:text-white marker:hidden">
              <span class="inline-flex w-full items-center justify-between gap-4">
                <span>{faq.question}</span>
                <span class="shrink-0 text-gray-400 group-open:rotate-45 transition-transform">+</span>
              </span>
            </summary>
            <p class="mt-3 leading-relaxed text-gray-600 dark:text-gray-300">{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </section>

  <section class="mt-16 overflow-hidden rounded-3xl">
    <div class="relative">
      <div
        class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-800 to-sky-900 dark:from-gray-800 dark:via-gray-900 dark:to-sky-950"
        aria-hidden="true"
      >
      </div>
      <div class="relative px-6 py-16 text-center sm:px-12">
        <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">
          {page.ctaHeading}
        </h2>
        <p class="mx-auto mt-3 max-w-xl text-base text-gray-300">
          {page.ctaBody}
        </p>
        <div class="mt-8">
          <a
            href="https://apps.apple.com/app/6758926117"
            target="_blank"
            class="inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3 text-sm font-semibold text-gray-900 no-underline hover:bg-gray-100 transition-colors shadow-lg"
          >
            <Download class="h-4 w-4" />
            {t("hero.download")}
          </a>
        </div>
      </div>
    </div>
  </section>
</article>
