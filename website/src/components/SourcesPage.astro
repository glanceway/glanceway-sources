---
import SourceCard from "./SourceCard.astro";
import CategoryTabs from "./CategoryTabs.astro";
import { getSources } from "../lib/sources";
import { useTranslations } from "../i18n/index";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const sources = getSources();
---

<div>
  <div class="mx-auto max-w-6xl px-6 py-14">
    <div class="mb-10">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
          <h1
            class="mb-2 text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl dark:text-white"
          >
            {t("sources.pageTitle")}
          </h1>
          <p class="text-gray-500 dark:text-gray-400">
            {t("sources.pageSubtitle")}
          </p>
          <p class="mt-1 text-sm text-gray-400 dark:text-gray-500">
            {t("sources.rssNote")}
            <a
              href="https://rsshub.netlify.app/routes"
              class="text-gray-500 underline hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 transition-colors"
              target="_blank">RSSHub</a
            > / <a
              href="https://rss.app"
              class="text-gray-500 underline hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 transition-colors"
              target="_blank">rss.app</a
            >.
          </p>
        </div>
        <a
          href="https://github.com/glanceway/glanceway-sources/blob/master/docs/README.md"
          class="shrink-0 self-start rounded-xl border border-gray-200 dark:border-gray-700 px-4 py-2 text-sm font-medium text-gray-700 no-underline hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800 transition-colors"
          target="_blank">{t("sources.buildSource")}</a
        >
      </div>
    </div>

    <CategoryTabs locale={locale} active="All" />

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        sources.map((s) => (
          <SourceCard
            id={s.id}
            name={s.name}
            description={s.description}
            category={s.category}
            tags={s.tags}
            author={s.author}
            type={s.type}
            locale={locale}
          />
        ))
      }
    </div>
  </div>
</div>
