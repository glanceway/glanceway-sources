---
import SourceCard from "./SourceCard.astro";
import { getSources } from "../lib/sources";
import { useTranslations } from "../i18n/index";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const sources = getSources();
const categories = [
  "All",
  "Developer",
  "News",
  "Social",
  "Finance",
  "Entertainment",
  "Productivity",
  "Other",
];
---

<div>
  <div class="mx-auto max-w-6xl px-6 py-14">
    <div class="mb-10">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
          <h1
            class="mb-2 text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl dark:text-white"
          >
            {t("sources.pageTitle")}
          </h1>
          <p class="text-gray-500 dark:text-gray-400">
            {t("sources.pageSubtitle")}
          </p>
          <p class="mt-1 text-sm text-gray-400 dark:text-gray-500">
            {t("sources.rssNote")}
            <a
              href="https://rsshub.netlify.app/routes"
              class="text-gray-500 underline hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 transition-colors"
              target="_blank">RSSHub</a
            > / <a
              href="https://rss.app"
              class="text-gray-500 underline hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 transition-colors"
              target="_blank">rss.app</a
            >.
          </p>
        </div>
        <a
          href="https://github.com/glanceway/glanceway-sources/blob/master/docs/README.md"
          class="shrink-0 self-start rounded-xl border border-gray-200 dark:border-gray-700 px-4 py-2 text-sm font-medium text-gray-700 no-underline hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800 transition-colors"
          target="_blank">{t("sources.buildSource")}</a
        >
      </div>
    </div>

    <div class="mb-6 flex flex-wrap gap-2">
      {
        categories.map((cat) => (
          <button
            class="category-tab rounded-full px-3.5 py-1.5 text-sm font-medium transition-colors"
            data-category={cat}
          >
            {t(`category.${cat}` as any)}
          </button>
        ))
      }
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" id="grid">
      {
        sources.map((s) => (
          <SourceCard
            id={s.id}
            name={s.name}
            description={s.description}
            category={s.category}
            tags={s.tags}
            author={s.author}
            type={s.type}
            locale={locale}
          />
        ))
      }
    </div>
    <div id="empty-state" class="hidden py-16 text-center">
      <p class="text-lg text-gray-400 dark:text-gray-500">
        {t("sources.emptyTitle")}
      </p>
      <p class="mt-2 text-sm text-gray-400 dark:text-gray-500">
        {t("sources.emptySubtitle")}
      </p>
      <a
        href="https://github.com/glanceway/glanceway-sources/blob/master/docs/README.md"
        class="mt-4 inline-block btn-primary"
        target="_blank">{t("sources.buildSource")}</a
      >
    </div>
  </div>
</div>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".category-tab");
  const cards = document.querySelectorAll<HTMLAnchorElement>("#grid > a");
  const emptyState = document.getElementById("empty-state")!;

  function setActive(tab: HTMLButtonElement) {
    tabs.forEach((t) => t.classList.remove("active"));
    tab.classList.add("active");
  }

  function filter(category: string) {
    let visible = 0;
    cards.forEach((card) => {
      if (category === "All" || card.dataset.category === category) {
        card.style.display = "";
        visible++;
      } else {
        card.style.display = "none";
      }
    });
    emptyState.classList.toggle("hidden", visible > 0);
  }

  function applyCategory(cat: string, updateUrl: boolean) {
    const tab = Array.from(tabs).find((t) => t.dataset.category === cat) ?? tabs[0];
    setActive(tab);
    filter(tab.dataset.category!);
    if (updateUrl) {
      const url = new URL(window.location.href);
      if (tab.dataset.category === "All") {
        url.searchParams.delete("category");
      } else {
        url.searchParams.set("category", tab.dataset.category!);
      }
      history.replaceState(null, "", url.toString());
    }
  }

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      applyCategory(tab.dataset.category!, true);
    });
  });

  // Initial: restore from URL, default to "All"
  const initial = new URL(window.location.href).searchParams.get("category") ?? "All";
  applyCategory(initial, false);
</script>
